# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# ── Runtime / user data (never commit to source control) ─────────────────────
# saved_analyses.json contains user-uploaded ad data and saved analysis state.
saved_analyses.json

# ── Replit platform files (not needed outside Replit) ────────────────────────
.replit
.replitignore
.cache/
.config/
.local/
.agents/
.pythonlibs/

# ── Uploaded / generated assets that may contain proprietary data ─────────────
attached_assets/

# ── Node / JS dependencies ────────────────────────────────────────────────────
node_modules
dist
tmp
out-tsc
*.tsbuildinfo
.expo
.expo-shared

# ── IDEs and editors ─────────────────────────────────────────────────────────
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ── Misc ──────────────────────────────────────────────────────────────────────
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings
.DS_Store
Thumbs.db
