# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
.venv/
venv/
.env

# ── Runtime / user data (never commit to source control) ─────────────────────
# saved_analyses.json contains user-uploaded ad data and saved analysis state.
# NOTE: if this file is already tracked, run: git rm --cached saved_analyses.json
saved_analyses.json
data/
exports/
*.log

# ── Replit platform files (required for Replit to run; not needed elsewhere) ──
.replit
.replitignore
replit.md
.cache/
.config/
.local/
.agents/
.pythonlibs/

# ── Node / PNPM / TypeScript workspace (Replit platform scaffolding) ──────────
# These files support the Replit agent environment and are NOT part of the
# Streamlit app. A GitHub clone only needs app.py, utils/, requirements.txt,
# sample_data/, and .streamlit/.
node_modules/
artifacts/
lib/
scripts/
package.json
pnpm-lock.yaml
pnpm-workspace.yaml
tsconfig.json
tsconfig.base.json
.npmrc
dist/
build/
out-tsc/
*.tsbuildinfo
.expo
.expo-shared

# ── Uploaded / generated assets that may contain proprietary data ─────────────
attached_assets/

# ── IDEs and editors ─────────────────────────────────────────────────────────
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ── Misc ──────────────────────────────────────────────────────────────────────
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings
.DS_Store
Thumbs.db
.ipynb_checkpoints/
